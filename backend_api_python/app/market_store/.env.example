# ============================================================
# Market Data Feather Store — 环境变量配置
# ============================================================

# 数据采集间隔（秒），默认 300 = 5分钟
FEATHER_FETCH_INTERVAL=300

# 数据保留天数，超过自动删除，默认 15
FEATHER_RETENTION_DAYS=15

# feather 文件存储目录（相对于本脚本的路径，或绝对路径）
FEATHER_DATA_DIR=./data/feather

# 是否在启动时打印详细日志
FEATHER_VERBOSE=1

# ============================================================
# 急剧变化检测配置
# ============================================================

# 回看最近 N 条历史数据进行比对（默认 15）
FEATHER_ANOMALY_WINDOW=15

# z-score 阈值：变动偏离历史均值多少个标准差算"急剧"（默认 2.5）
FEATHER_ANOMALY_ZSCORE=2.5

# 最小变动百分比：低于此值不告警，过滤正常波动（默认 2.0%）
FEATHER_ANOMALY_MIN_PCT=2.0

# 同一标的告警冷却时间（秒），防止刷屏（默认 600 = 10分钟）
FEATHER_ANOMALY_COOLDOWN=600

# ============================================================
# 容错 & 数据质量配置
# ============================================================

# 单次最大合理价格变动%（超过视为采集错误，丢弃该数据，默认 50%）
FEATHER_SANITY_MAX_PCT=50.0

# 最低采集完整率（实际采集数/预期数，低于此值不触发异常检测，默认 0.5 = 50%）
FEATHER_MIN_FETCH_RATIO=0.5

# 是否启用缺失数据回填（1=开启，采集不到的标的沿用上次数据，默认开启）
FEATHER_FILL_MISSING=1
